{
  "name": "afip_electron",
  "version": "1.0.1",
  "main": "src/backend/home/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@puppeteer/browsers": "^2.10.6",
    "electron": "^33.3.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "iconv-lite": "^0.6.3",
    "luxon": "^3.5.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "puppeteer-core": "^24.1.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.tuorganizacion.afipelectron",
    "productName": "AFIP Electron",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ]
    }
  }
}
